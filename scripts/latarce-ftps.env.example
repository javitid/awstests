FTP_USER='agente@latarce.es'
FTP_PASS='<replace-me>'
FTP_HOST='ftp.covaresa.com'
FTP_PORT='21'

# Directorio remoto de despliegue.
# Ejemplos:
# REMOTE_PATH='/public_html/'
# REMOTE_PATH='/public_html/awstests/'
REMOTE_PATH=''

# Solo si de verdad quieres limpiar y desplegar en la raiz remota.
ALLOW_REMOTE_ROOT_CLEAN='no'

# Actívalo solo si el servidor FTPS presenta un certificado no válido
# para el hostname configurado.
FTP_INSECURE='no'

# Actívalo si el servidor falla subiendo archivos con el canal de datos cifrado.
FTP_CONTROL_ONLY_TLS='no'
